<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0E8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Formulaire"
            android:textSize="26sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nom &amp; Prénom"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#5C3D2E"/>
        <EditText
            android:id="@+id/nom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="KASRAOUI Fatima Ezzahra"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:textColorHint="#A0927E"
            android:backgroundTint="#8B5E3C"
            android:inputType="textPersonName"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Email"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#5C3D2E"/>
        <EditText
            android:id="@+id/email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex : user@gmail.com"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:textColorHint="#A0927E"
            android:backgroundTint="#8B5E3C"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Téléphone"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#5C3D2E"/>
        <EditText
            android:id="@+id/phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ex : +212676000000"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:textColorHint="#A0927E"
            android:backgroundTint="#8B5E3C"
            android:inputType="phone"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Adresse"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#5C3D2E"/>
        <EditText
            android:id="@+id/adresse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mon adresse, Marrakech"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:textColorHint="#A0927E"
            android:backgroundTint="#8B5E3C"
            android:inputType="textPostalAddress"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ville"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:textColor="#5C3D2E"/>
        <EditText
            android:id="@+id/ville"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Marrakech 40000"
            android:fontFamily="serif"
            android:textColor="#2C2C2C"
            android:textColorHint="#A0927E"
            android:backgroundTint="#8B5E3C"
            android:inputType="textCapWords"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnEnvoyer"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Envoyer →"
            android:textSize="16sp"
            android:textStyle="bold"
            android:fontFamily="serif"
            android:backgroundTint="#8B5E3C"/>

    </LinearLayout>
</ScrollView>